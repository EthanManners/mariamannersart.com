# Copy this file to `.env` on the server and fill in real values.
# The real `.env` is gitignored and must never be committed.

# Stripe secret key (sk_test_... for testing, sk_live_... in production).
# This stays server-side only and is the single secret that authorizes charges.
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe publishable key (pk_test_... / pk_live_...). Safe to expose to the
# browser; the server hands it out via GET /api/config.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Stripe webhook signing secret (whsec_...). Used to verify POST /api/webhook
# events. From `stripe listen` (CLI) or the Dashboard webhook endpoint. The
# service still runs without it, but webhook events are rejected (503) until set.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Port the service listens on (optional; defaults to 8787).
PORT=8787

# Bind address (optional; defaults to 0.0.0.0). In production set to 127.0.0.1 so
# the port is only reachable through the local nginx reverse proxy.
HOST=127.0.0.1
